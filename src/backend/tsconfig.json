{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "forceConsistentCasingInFileNames": true,
    "rewriteRelativeImportExtensions": true,
    "paths": {
      "@contract/*": ["../contract/*"]
    }
  },
  "include": ["src/server/**/*.ts", "src/core/**/*.ts", "src/bridge/**/*.ts", "src/cli.ts", "../contract/**/*.ts"]
}
