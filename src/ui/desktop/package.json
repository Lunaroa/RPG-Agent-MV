{
  "name": "desktop",
  "private": true,
  "version": "0.2.2",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "prepare:electron-runtime": "install-electron",
    "prepackage": "npm run prepare:electron-runtime && npm --prefix ../../.. run build:opencode-runtime",
    "package": "electron-builder --config electron-builder.json --win --x64",
    "package:build": "npm run build && npm run package",
    "preview": "vite preview"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@lucide/vue": "^1.18.0",
    "element-plus": "^2.14.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "electron": "^42.3.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^0.29.1",
    "vue-tsc": "^3.2.8"
  }
}
